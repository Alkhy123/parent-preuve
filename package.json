{
  "name": "parent-preuve",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--use-system-ca next dev",
    "check:agent-boundaries": "node scripts/check-agent-boundaries.mjs",
    "check:ia-consent": "node scripts/check-ia-consent-boundaries.mjs",
    "check:multi-procedure-migration": "node scripts/check-multi-procedure-migration.mjs",
    "check": "npm run check:agent-boundaries && npm run check:ia-consent && npm run check:multi-procedure-migration && npm run lint",
    "build": "npm run check && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --import ./tests/setup.ts --test \"tests/**/*.test.ts\"",
    "e2e:compte": "node scripts/creer-compte-test.mjs",
    "e2e:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "capture:ui": "node scripts/captures-ui.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
