# .env.example — modèle de configuration.
# À COPIER en .env.local, puis à remplir avec vos vraies valeurs.
# Ne mettez JAMAIS de vraie valeur ici : ce fichier est suivi par Git.

# --- Supabase (projet) ---
# URL du projet Supabase (visible côté navigateur).
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique Supabase, protégée par la RLS (visible côté navigateur).
# "publishable" est le nom récent ; "anon" est l'ancien. UNE SEULE suffit :
# le code lit PUBLISHABLE en priorité, sinon il se rabat sur ANON.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service (administrateur) — SERVEUR UNIQUEMENT, jamais exposée au navigateur.
SUPABASE_SERVICE_ROLE_KEY=

# --- Mistral AI ---
# Accès à l'API Mistral (appels serveur uniquement).
MISTRAL_API_KEY=

# --- Horodatage ---
# Secret de signature de l'horodatage — SERVEUR UNIQUEMENT.
# Générer une valeur (Windows, sans OpenSSL) :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HORODATAGE_SECRET=
